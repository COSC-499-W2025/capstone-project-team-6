POSTGRES_DB=vector_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

ENVIRONMENT=production

ANALYSIS_DB_PATH=/app/data/analysis.db
DOCUMENTS_DB_PATH=/app/data/documents.db

